---
import LandingLayout from "../layouts/LandingLayout.astro";
import { Button } from "@/components/ui/button";
import {
  ArrowRight,
  BarChart3,
  Users,
  Box,
  CreditCard,
  Sparkles,
  TrendingUp,
  Layers,
} from "lucide-react";
---

<LandingLayout
  title="Ethereal SaaS - Gestión Multi-Tenant Liquid Glass"
  description="La arquitectura multi-tenant más rápida del mercado."
>
  <main class="flex-1 w-full bg-surface pt-32 pb-16">
    <!-- Hero Section -->
    <section
      class="max-w-7xl mx-auto px-6 pt-16 pb-24 lg:pt-32 lg:pb-32 relative"
    >
      <div
        class="absolute inset-0 -z-10 h-full w-full bg-surface bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-40"
      >
      </div>

      <div
        class="max-w-4xl max-w-4xl mx-auto text-center space-y-8 animate-in fade-in slide-in-from-bottom-8 duration-1000"
      >
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-high border border-white/40 shadow-sm text-sm font-medium text-primary mb-6"
        >
          <Sparkles className="w-4 h-4 text-primary" />
          <span>Gestión Multi-Tenant</span>
        </div>

        <h1
          class="text-5xl md:text-7xl font-heading font-bold text-foreground tracking-tight leading-[1.1]"
        >
          La arquitectura multi-tenant <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#81d9a0]"
            >más rápida</span
          > del mercado.
        </h1>

        <p
          class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto"
        >
          Centraliza inventarios, equipos y finanzas con la elegancia de una
          herramienta editorial y el poder de un motor industrial.
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-8"
        >
          <Button
            size="lg"
            className="rounded-full bg-gradient-to-br from-primary to-primary-container hover:shadow-xl hover:shadow-primary/20 hover:-translate-y-0.5 transition-all duration-300 text-white border-0 h-14 px-8 text-base"
          >
            Comenzar prueba gratis <ArrowRight className="ml-2 w-5 h-5" />
          </Button>
          <Button
            variant="outline"
            size="lg"
            className="rounded-full h-14 px-8 text-base border-border bg-transparent hover:bg-surface-container-low transition-colors text-foreground"
          >
            Ver demostración
          </Button>
        </div>
        <p class="text-sm text-muted-foreground mt-4">
          Sin tarjeta de crédito. 14 días de prueba.
        </p>
      </div>
    </section>

    <!-- Stats / Dashboard Preview Section -->
    <section class="max-w-7xl mx-auto px-6 py-20 relative z-10">
      <!-- Image Placeholder for the actual system -->
      <div class="mb-20 animate-in fade-in zoom-in duration-1000 delay-300">
        <div class="relative mx-auto max-w-5xl">
          <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-chart-3/20 rounded-[2.5rem] blur-2xl opacity-50"></div>
          <div class="relative bg-surface-container-low rounded-[2rem] border border-white/40 overflow-hidden shadow-2xl">
            <div class="aspect-video flex items-center justify-center bg-muted/30">
               <div class="text-center p-12">
                 <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
                   <TrendingUp className="w-10 h-10 text-primary" />
                 </div>
                 <h2 class="text-2xl font-heading font-bold text-foreground mb-4">Vista Previa de la Plataforma</h2>
                 <p class="text-muted-foreground max-w-md mx-auto">
                   Aquí puedes colocar una captura de pantalla de tu sistema de inventarios actual para mostrar la interfaz real a tus usuarios.
                 </p>
               </div>
            </div>
            <!-- Mock browser top bar -->
            <div class="absolute top-0 left-0 right-0 h-10 bg-white/20 backdrop-blur-md border-b border-white/20 flex items-center px-4 gap-2">
              <div class="w-3 h-3 rounded-full bg-red-400/50"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400/50"></div>
              <div class="w-3 h-3 rounded-full bg-green-400/50"></div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="bg-surface-container-lowest/80 backdrop-blur-2xl rounded-3xl p-8 md:p-12 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.05)] border border-white/60"
      >
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="space-y-4">
            <div
              class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center"
            >
              <Layers className="w-6 h-6 text-primary" />
            </div>
            <h3 class="font-heading font-semibold text-xl text-foreground">
              Tu Dashboard Líquido
            </h3>
            <p class="text-muted-foreground text-sm">
              Arquitectura de cristal multi-tenant diseñada para escalar.
            </p>
          </div>
          <div class="space-y-4">
            <div
              class="w-12 h-12 rounded-2xl bg-chart-3/20 flex items-center justify-center"
            >
              <BarChart3 className="w-6 h-6 text-chart-3" />
            </div>
            <h3 class="font-heading font-semibold text-xl text-foreground">
              Actividad En Tiempo Real
            </h3>
            <p class="text-muted-foreground text-sm">
              Sincronización instantánea en todos tus workspaces y cuentas
              conectadas.
            </p>
          </div>
          <div class="space-y-4">
            <div
              class="w-12 h-12 rounded-2xl bg-chart-2/10 flex items-center justify-center"
            >
              <TrendingUp className="w-6 h-6 text-chart-2" />
            </div>
            <h3 class="font-heading font-semibold text-xl text-foreground">
              Crecimiento +24.5%
            </h3>
            <p class="text-muted-foreground text-sm">
              Rendimiento óptimo proyectado gracias a la eficiencia de la
              infraestructura.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="max-w-7xl mx-auto px-6 py-24">
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
        <h2 class="text-3xl md:text-5xl font-heading font-bold text-foreground">
          Diseñado para la eficiencia.
        </h2>
        <p class="text-lg text-muted-foreground">
          Cuatro pilares fundamentales para escalar tu negocio sin límites.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Feature 1 -->
        <div
          class="bg-surface-container-low rounded-[2rem] p-10 hover:bg-surface-container hover:shadow-lg transition-all duration-500 group"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300"
          >
            <Box className="w-7 h-7 text-primary" />
          </div>
          <h3 class="text-2xl font-heading font-semibold text-foreground mb-4">
            Gestión de Inventario
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Control en tiempo real de múltiples almacenes. Sincronización
            inteligente entre tenants para una logística impecable.
          </p>
        </div>

        <!-- Feature 2 -->
        <div
          class="bg-surface-container-low rounded-[2rem] p-10 hover:bg-surface-container hover:shadow-lg transition-all duration-500 group"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300"
          >
            <CreditCard className="w-7 h-7 text-primary" />
          </div>
          <h3 class="text-2xl font-heading font-semibold text-foreground mb-4">
            Gastos & Finanzas
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Auditoría transparente de cada centavo. Reportes automáticos y
            conciliación bancaria en un click.
          </p>
        </div>

        <!-- Feature 3 -->
        <div
          class="bg-surface-container-low rounded-[2rem] p-10 hover:bg-surface-container hover:shadow-lg transition-all duration-500 group"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300"
          >
            <Users className="w-7 h-7 text-primary" />
          </div>
          <h3 class="text-2xl font-heading font-semibold text-foreground mb-4">
            Gestión de Empleados
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Roles granulares por empresa. Control de accesos y nóminas
            unificadas bajo un mismo ecosistema.
          </p>
        </div>

        <!-- Feature 4 -->
        <div
          class="bg-surface-container-low rounded-[2rem] p-10 hover:bg-surface-container hover:shadow-lg transition-all duration-500 group"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300"
          >
            <Layers className="w-7 h-7 text-primary" />
          </div>
          <h3 class="text-2xl font-heading font-semibold text-foreground mb-4">
            Membresías SaaS
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Crea tus propios planes. Facturación recurrente y gestión de
            clientes finales integrada nativamente.
          </p>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="max-w-5xl mx-auto px-6 py-24 text-center">
      <div
        class="bg-gradient-to-br from-primary to-primary-container rounded-[3rem] p-12 md:p-20 shadow-2xl shadow-primary/20 relative overflow-hidden text-white"
      >
        <!-- Floating circles for decoration -->
        <div
          class="absolute -top-24 -right-24 w-64 h-64 bg-white/10 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute -bottom-24 -left-24 w-80 h-80 bg-white/10 rounded-full blur-3xl"
        >
        </div>

        <div class="relative z-10 space-y-8">
          <h2
            class="text-4xl md:text-5xl font-heading font-bold text-white leading-tight"
          >
            Únete a cientos de empresas que ya optimizan su operación
          </h2>
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <Button
              size="lg"
              className="rounded-full bg-white text-primary hover:bg-surface-container-lowest hover:shadow-lg transition-all duration-300 h-14 px-10 text-base font-bold border-0"
            >
              Comenzar prueba gratis
            </Button>
          </div>
          <p class="text-white/80 text-sm">
            Sin tarjeta de crédito. 14 días de prueba.
          </p>
        </div>
      </div>
    </section>
  </main>
</LandingLayout>
