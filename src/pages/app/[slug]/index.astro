---
import AppLayout from "../../../layouts/AppLayout.astro";
import { supabase } from "../../../lib/supabase";
export const prerender = false;

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

await supabase.auth.setSession({
    refresh_token: refreshToken!.value,
    access_token: accessToken!.value,
});

const {
    data: { user },
} = await supabase.auth.getUser();
const metadata = user?.user_metadata;

const { data: empresas } = await supabase
    .from("empresas")
    .select("nombre, slug");

const currentEmpresa = empresas?.find((e) => e.slug === Astro.params.slug);
---

<AppLayout
    title={`Inicio - ${currentEmpresa?.nombre}`}
    slug={currentEmpresa?.slug ?? ""}
    companyName={currentEmpresa?.nombre ?? ""}
    currentPage="Inicio"
    empresas={empresas ?? []}
    userName={`${metadata?.first_name ?? ""} ${metadata?.last_name ?? ""}`.trim() || user?.email?.split("@")[0] || "Usuario"}
    userEmail={user?.email ?? ""}
>
    <h1 class="text-2xl font-bold">Bienvenido a {currentEmpresa?.nombre}</h1>
    <p class="text-muted-foreground">
        Panel principal de tu empresa. Usa el menú lateral para navegar.
    </p>
</AppLayout>
